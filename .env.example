ENVIRONMENT=LOCAL
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=financial_health
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://localhost:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

SENTRY_DSN=
OTEL_ENABLED=False

MEDIA_ROOT=media
STATEMENT_MAX_UPLOAD_BYTES=10485760
STATEMENT_ALLOWED_EXTENSIONS=csv,pdf,xls,xlsx
PDF_MIN_TEXT_CHARS_PER_PAGE=20
PDF_MIN_TOTAL_TEXT_CHARS=50
XLSX_HEADER_SCAN_ROWS=30
STATEMENT_DELETE_RAW_AFTER_PARSE=True
STATEMENT_RAW_RETENTION_SECONDS=0

INSIGHT_LOW_SAVINGS_THRESHOLD_PCT=10.0
INSIGHT_GOOD_SAVINGS_THRESHOLD_PCT=20.0
INSIGHT_HIGH_EMI_THRESHOLD_PCT=40.0
INSIGHT_RISING_SPEND_THRESHOLD_PCT=15.0

# Gemini (optional — AI categorization for uncategorized merchants)
GEMINI_API_KEY=
GEMINI_ENABLED=True
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BATCH_SIZE=20
GEMINI_MAX_BATCHES_PER_REQUEST=1
GEMINI_COST_INPUT_PER_MILLION_USD=0.15
GEMINI_COST_OUTPUT_PER_MILLION_USD=0.60
